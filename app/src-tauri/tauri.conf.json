{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Savehop",
  "version": "0.1.0",
  "identifier": "dev.savehop.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Savehop",
        "width": 460,
        "height": 780,
        "minWidth": 420,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Co-op save sync for Windows",
    "longDescription": "Savehop lets friends share a single co-op save without a dedicated server. Wake to claim the save, play, then Sleep to hand it off.",
    "copyright": "MIT — Savehop contributors",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {}
}
